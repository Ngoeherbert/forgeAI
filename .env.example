# ---- forgeAI environment ----

# Neon Postgres (required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Server
PORT=8787
NODE_ENV=development
APP_URL=http://localhost:5173

# Better Auth
BETTER_AUTH_SECRET="replace-me-with-openssl-rand-hex-32"
BETTER_AUTH_URL=http://localhost:8787

# Social providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Neon Auth (Stack Auth) — optional; Better Auth tables are Neon-Auth compatible
STACK_PROJECT_ID=
STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# LLM (OpenAI-compatible endpoint)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Agent sandbox working directory
AGENT_WORKDIR=.agent-workdir
